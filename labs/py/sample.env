# Azure Foundry project endpoint (required)
AZURE_AI_PROJECT_ENDPOINT="https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>"

# Model deployment name (required — deploy a model first in the Foundry portal)
MODEL_DEPLOYMENT_NAME="gpt-4.1"

# For red-teaming (Task 08)
MODEL_ENDPOINT="https://<your-ai-services>.services.ai.azure.com"
MODEL_API_KEY="<your-model-api-key>"

# For tracing (Task 07)
TELEMETRY_CONNECTION_STRING="InstrumentationKey=<your-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/"

# For fine-tuning deployment (Task 04c)
AZURE_AI_PROJECTS_AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_AI_PROJECTS_AZURE_RESOURCE_GROUP="<your-resource-group>"
AZURE_AI_PROJECTS_AZURE_AOAI_ACCOUNT="<your-aoai-account-name>"
