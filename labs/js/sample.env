# Microsoft Foundry Project endpoint (from portal overview page)
AZURE_AI_PROJECT_ENDPOINT="<project endpoint from Microsoft Foundry>"

# Model deployment name (e.g., gpt-4.1 or gpt-4.1-mini)
MODEL_DEPLOYMENT_NAME="<model deployment name>"

# Model endpoint and API key (used for red-teaming scans)
MODEL_ENDPOINT="<model endpoint url>"
MODEL_API_KEY="<model api key>"

# Application Insights connection string (for tracing / telemetry)
TELEMETRY_CONNECTION_STRING="<your Application Insights connection string>"
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true

# Fine-tuning deployment configuration
AZURE_AI_PROJECTS_AZURE_SUBSCRIPTION_ID="<azure subscription id>"
AZURE_AI_PROJECTS_AZURE_RESOURCE_GROUP="<azure resource group>"
AZURE_AI_PROJECTS_AZURE_AOAI_ACCOUNT="<azure openai account name>"

# Reduce logging verbosity for Azure SDKs (optional)
AZURE_LOG_LEVEL="error"
